# Configuracion del stack Docker (docker-compose.yml).
# Copiar a ".env" y poner valores PROPIOS DE ESTA INSTALACION.
#
#   cp .env.example .env
#
# Cada cliente debe tener secretos distintos. Si repetis los mismos en todas
# las instalaciones, quien vea una puede entrar a cualquier otra.
# Generar valores al azar (con Docker ya instalado, no hace falta nada mas):
#
#   docker run --rm node:24-slim node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"

# Clave de root de MySQL. La base no se expone fuera del PC, pero igual: al azar.
MYSQL_ROOT_PASSWORD=

# Secreto para firmar los tokens de sesion (JWT).
# Si alguien lo conoce, puede fabricarse una sesion de administrador.
JWT_SECRET=

# Clave inicial del usuario admin. Opcional: si la dejas vacia, el seed genera
# una al azar y la imprime UNA vez en los logs.
# ADMIN_PASSWORD=

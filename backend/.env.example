# Copia este archivo a .env y ajusta tus credenciales de MySQL.
# La base NO usa llaves foraneas: las tablas estan bien definidas pero
# las relaciones se resuelven por valor de id en el codigo (relationMode = prisma).
DATABASE_URL="mysql://root:password@localhost:3306/motopos"
PORT=5180
JWT_SECRET="cambia-esto-por-un-secreto-largo"

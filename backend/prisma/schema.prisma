// MotoPOS V3 - Esquema MySQL "sin relaciones".
// Tablas bien definidas, pero NO se declaran @relation ni llaves foraneas:
// las referencias (clientDoc, saleId, etc.) son columnas escalares que se
// resuelven por valor en el codigo. relationMode = "prisma" evita FKs en MySQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

/// Terceros / clientes. La placa NO vive aqui (va en Vehicle).
model Client {
  id             Int      @id @default(autoincrement())
  docType        String   @default("CC")
  docNumber      String   @unique
  dv             String?
  personType     String   @default("NATURAL")
  name           String
  commercialName String?
  email          String?
  phone          String?
  phones         Json? // telefonos adicionales (lista); `phone` sigue siendo el principal
  address        String?
  status         String   @default("ACTIVO")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([name])
  @@map("clients")
}

/// Motos. Un cliente puede tener varias (referencia por clientDoc, sin FK).
model Vehicle {
  id          Int      @id @default(autoincrement())
  clientDoc   String
  plate       String
  modelYear   Int?
  rangeName   String?
  vehicleType String   @default("MOTO")
  status      String   @default("ACTIVO")
  createdAt   DateTime @default(now())

  @@index([clientDoc])
  @@index([plate])
  @@map("vehicles")
}

/// Convenios / aliados / referidos. "USUARIO" = cliente directo (fidelizado).
model Ally {
  id            Int      @id @default(autoincrement())
  name          String
  contactPhone  String?
  altPhone      String?
  docType       String?
  docNumber     String?
  paymentMethod String?
  accountNumber String?
  holderDocType String?
  holderDoc     String?
  address       String?
  company       String?
  observation   String?  @db.Text
  notes         String?  @db.Text
  enrolled      Boolean  @default(false)
  commission    Int      @default(40000)
  isDirectUser  Boolean  @default(false)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([name])
  @@map("allies")
}

/// Componentes fiscales internos (servicio, RUNT, SICOV, recaudo, ANSV).
/// unitPrice es IVA-incluido (precio final); taxRate es el % embebido.
model Product {
  id          Int     @id @default(autoincrement())
  code        String  @unique
  name        String
  unitPrice   Int
  taxRate     Int     @default(0)
  vehicleType String  @default("MOTO")
  active      Boolean @default(true)

  @@map("products")
}

/// Tarifas/costos operativos por tipo de vehiculo, con vigencia.
/// concept: SICOV | RECAUDO | FUPA | SUSTRATOS | IVA_FACT | IVA_RATE | ANSV
/// Para ANSV se usan yearFrom/yearTo (rango del modelo). value en COP
/// (para IVA_RATE, value = porcentaje, ej. 19).
model Tariff {
  id          Int     @id @default(autoincrement())
  vehicleType String  @default("MOTO")
  concept     String
  value       Int
  yearFrom    Int     @default(0)
  yearTo      Int     @default(9999)
  validFrom   String  @default("2026-01-01")
  active      Boolean @default(true)

  @@index([vehicleType, concept])
  @@map("tariffs")
}

/// Combos RTM visibles para la venta (uno por rango de modelo).
model Package {
  id          Int     @id @default(autoincrement())
  code        String  @unique
  name        String
  rangeName   String
  vehicleType String  @default("MOTO")
  active      Boolean @default(true)

  @@map("packages")
}

/// Relacion paquete -> componentes (por valor de codigo, sin FK).
model PackageComponent {
  id            Int    @id @default(autoincrement())
  packageCode   String
  productCode   String
  quantity      Int    @default(1)
  priceOverride Int?

  @@index([packageCode])
  @@map("package_components")
}

/// Catalogo de metodos de pago con su regla de costo y comportamiento fiscal.
/// groupCode: SG (Supergiros) | CM (Certimotos/empresa) | CREDITO
/// costType: none | percent | fixed | percent_plus_tax
model PaymentMethod {
  id                  Int     @id @default(autoincrement())
  code                String  @unique
  name                String
  groupCode           String
  isCredit            Boolean @default(false)
  generatesReceivable Boolean @default(false)
  facturaDian         Boolean @default(false)
  costType            String  @default("none")
  costRate            Float   @default(0)
  costAmount          Int     @default(0)
  costTaxRate         Float   @default(0)
  active              Boolean @default(true)

  @@map("payment_methods")
}

/// Cabecera de venta/servicio. Columnas planas indexadas para buscar/cuadrar.
model Sale {
  id                   Int      @id @default(autoincrement())
  saleNumber           String   @unique
  saleDate             String // YYYY-MM-DD (dia operativo del cierre)
  saleTime             String?
  shiftId              Int? // turno en el que se factura (null para ventas previas a turnos)
  clientDoc            String
  clientName           String
  plate                String?
  modelYear            Int?
  rangeName            String?
  vehicleType          String   @default("MOTO")
  packageCode          String?
  allyId               Int?
  allyName             String?
  allyType             String   @default("usuario") // usuario | referido
  discountApplied      Boolean  @default(true)
  deduction            Int      @default(0) // DEDUCCIONES CONVENIOS
  commissionPaidBy     Int? // id del AllyPayment que pago esta comision (null = pendiente)
  totalBase            Int      @default(0)
  totalIva             Int      @default(0)
  total                Int      @default(0)
  paidAmount           Int      @default(0)
  changeAmount         Int      @default(0)
  rtmAlreadyPaid       Boolean  @default(false)
  rtmToday             Boolean  @default(true)
  rtmStatus            String   @default("done") // done | pending | paid_not_done
  pinAdquirido         Int      @default(0) // >0 => RTM realizada
  pinNumber            String?  // PIN SuperFlex/RUNT de 19 digitos cuando la RTM se realiza
  provisionAmount      Int      @default(0)
  provisionConsumed    Boolean  @default(false) // esta venta consumio una provision previa (no doble comision/ventas brutas)
  provisionSourcePlate String? // placa provisionada cuya provision se consumio
  receivableAmount     Int      @default(0)
  dianStatus           String   @default("no_emitida") // no_emitida | facturada
  invoiceNumber        String?
  cufe                 String?
  status               String   @default("activa") // activa | anulada
  responsable          String?
  observaciones        String?  @db.Text
  createdAt            DateTime @default(now())

  @@index([saleDate])
  @@index([clientDoc])
  @@index([plate])
  @@index([pinNumber])
  @@index([shiftId])
  @@index([commissionPaidBy])
  @@map("sales")
}

/// Turno de caja. Las ventas se facturan dentro de un turno ABIERTO; al cerrarlo
/// solo se hace el ARQUEO de efectivo (la dispersion del dinero ocurre en el CIERRE
/// DIARIO, no aqui). Puede haber varios turnos por dia (cambio de cajera);
/// solo uno abierto a la vez. `number` es un consecutivo GLOBAL unico (no se repite).
model Shift {
  id           Int       @id @default(autoincrement())
  businessDate String // YYYY-MM-DD (dia en que se abrio)
  number       Int       @unique // consecutivo global unico del turno
  status       String    @default("abierto") // abierto | cerrado
  openingCash  Int       @default(0) // base de efectivo con la que abre
  openedBy     String?
  openedAt     DateTime  @default(now())
  expectedCash Int       @default(0) // efectivo a entregar calculado (esperado)
  countedCash  Int? // efectivo contado fisicamente al cerrar (arqueo)
  cashDiff     Int       @default(0) // countedCash - expectedCash (sobrante/faltante)
  salesTotal   Int       @default(0)
  jasper       Int       @default(0)
  provision    Int       @default(0)
  closedBy     String?
  closedAt     DateTime?
  note         String?
  createdAt    DateTime  @default(now())

  @@index([businessDate])
  @@index([status])
  @@map("shifts")
}

/// Lineas fiscales internas de la venta (referencia por saleId, sin FK).
model SaleLine {
  id          Int    @id @default(autoincrement())
  saleId      Int
  productCode String
  description String
  quantity    Int    @default(1)
  unitPrice   Int
  taxRate     Int    @default(0)
  base        Int    @default(0)
  tax         Int    @default(0)
  total       Int    @default(0)

  @@index([saleId])
  @@map("sale_lines")
}

/// Pagos de la venta. PAGO MIXTO: varias filas por venta.
/// costAmount / costTax quedan CONGELADOS al registrar (no se recalculan).
model SalePayment {
  id         Int    @id @default(autoincrement())
  saleId     Int
  methodCode String
  methodName String
  groupCode  String
  amount     Int
  costType   String @default("none")
  costAmount Int    @default(0)
  costTax    Int    @default(0)

  @@index([saleId])
  @@index([methodCode])
  @@map("sale_payments")
}

/// Costos operativos congelados por venta (formato de cierre del Excel).
model SaleCost {
  id               Int @id @default(autoincrement())
  saleId           Int @unique
  sicov            Int @default(0)
  ivaSicov         Int @default(0)
  recaudo          Int @default(0)
  ivaRecaudo       Int @default(0)
  ansv             Int @default(0)
  fupa             Int @default(0)
  sustratos        Int @default(0)
  ivaFact          Int @default(0)
  costeTransaccion Int @default(0)
  costosTotal      Int @default(0)

  @@map("sale_costs")
}

/// Cartera: ADDI, GORA o credito propio. Saldo pendiente por venta.
model Receivable {
  id            Int       @id @default(autoincrement())
  saleId        Int
  provider      String
  clientDoc     String
  plate         String?
  amount        Int
  pending       Int
  status        String    @default("abierta") // abierta | pagada
  dueFrom       String
  invoiceNumber String? // # de factura con que se facturo esta placa (Gora/Addi)
  ica           Int       @default(0) // ICA descontado por el proveedor (acumulado de abonos)
  retefuente    Int       @default(0) // retencion en la fuente descontada (acumulado de abonos)
  paymentRef    String? // referencia/numero de credito del proveedor
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([provider])
  @@index([status])
  @@index([invoiceNumber])
  @@map("receivables")
}

/// Abonos de cartera por factura (Gora/Addi pagan por # de factura, con ICA y retefuente).
model ReceivablePayment {
  id            Int      @id @default(autoincrement())
  receivableId  Int
  provider      String
  invoiceNumber String?
  amount        Int // valor abonado (neto recibido)
  ica           Int      @default(0)
  retefuente    Int      @default(0)
  paidDate      String // YYYY-MM-DD
  note          String?
  createdAt     DateTime @default(now())

  @@index([receivableId])
  @@index([provider])
  @@map("receivable_payments")
}

/// Usuarios del sistema. role: admin | vendedor
model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  name         String
  passwordHash String
  role         String   @default("vendedor")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@map("users")
}

/// Factura emitida a partir de una venta (1 venta -> 0..1 factura).
/// La venta es el hecho; la factura es su emision fiscal.
model Invoice {
  id         Int      @id @default(autoincrement())
  saleId     Int      @unique
  number     String   @unique
  cufe       String?
  dianStatus String   @default("emitida_local") // emitida_local | aceptada | rechazada
  base       Int      @default(0)
  iva        Int      @default(0)
  total      Int      @default(0)
  issuedAt   DateTime @default(now())

  // --- Trazabilidad DIAN (estructura espejo del programa C# + apidian) ---
  environment  Int?     // 1 = produccion, 2 = pruebas/habilitacion
  authorization String? // numero de resolucion/autorizacion
  qrUrl        String?  @db.Text // url del QR DIAN
  softwareId   String?
  technicalKey String?
  xmlName      String?
  zipName      String?
  zipPath      String?  @db.Text
  sendStatus   String   @default("PENDIENTE") // PENDIENTE | ENVIADA | ACEPTADA | RECHAZADA | NO_APLICA
  dianIsValid  Boolean?
  dianTrackId  String?
  dianMessages String?  @db.Text
  lastSentAt   DateTime?
  validatedAt  DateTime?
  retries      Int      @default(0)
  sourceSystem String?

  @@index([sendStatus])
  @@map("invoices")
}

/// Configuracion de notificaciones (correo, Telegram, WhatsApp). Fila unica (id=1).
/// Email y Telegram replican las claves de easyerpweb (EmailApiUrl, TelegramBotToken,
/// TelegramHabilitado); WhatsApp se agrega para envios por la API de WhatsApp.
model NotificationConfig {
  id               Int      @id @default(1)
  emailEnabled     Boolean  @default(false)
  emailApiUrl      String?  // endpoint que envia el correo (POST { to, subject, message })
  emailFrom        String?
  telegramEnabled  Boolean  @default(false)
  telegramBotToken String?
  telegramChatId   String?
  whatsappEnabled  Boolean  @default(false)
  whatsappApiUrl   String?
  whatsappToken    String?
  whatsappPhoneId  String?
  updatedAt        DateTime @updatedAt

  @@map("notification_config")
}

/// Configuracion de la API DIAN (apidian). Fila unica (singleton, id=1).
/// Espejo de las claves del programa C#: NIT, token, URL apidian, set de pruebas, software.
model DianConfig {
  id           Int      @id @default(1)
  companyNit   String?
  companyDv    String?
  companyName  String?
  apidianUrl   String?  // ej: http://host:8085/api/ubl2.1
  apidianToken String?
  testSetId    String?  // DianTestId (set de pruebas / habilitacion)
  softwareId   String?
  softwarePin  String?
  environment  Int      @default(2) // 1 = produccion, 2 = pruebas
  resolution   String?
  prefix       String?
  emailApiUrl  String?
  active       Boolean  @default(false)
  updatedAt    DateTime @updatedAt

  @@map("dian_config")
}

/// Seguimiento de llamadas (gestion de vencimientos RTM y clientes por contactar).
/// status: pendiente | llamado | no_contesta | numero_errado | contestado | agendado | vino | no_vino
model CallLog {
  id           Int      @id @default(autoincrement())
  clientDoc    String?
  clientName   String?
  plate        String?
  phone        String?
  status       String   @default("pendiente")
  result       String?
  note         String?  @db.Text
  dueDate      String?  // vencimiento RTM asociado (YYYY-MM-DD)
  nextCallDate String?  // proxima llamada agendada
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clientDoc])
  @@index([status])
  @@map("call_logs")
}

/// Cuentas por pagar / obligaciones (modulo gerencial). frequency: unico | mensual | bimestral | cuotas
model Payable {
  id                Int      @id @default(autoincrement())
  concept           String
  creditor          String?  // a quien se le debe
  category          String?  // naturaleza: arriendo, nomina, cesantias, retencion, parafiscales, cuota, proveedor...
  totalAmount       Int      @default(0)
  paidAmount        Int      @default(0)
  frequency         String   @default("unico")
  installments      Int      @default(1)
  installmentAmount Int      @default(0)
  dueDate           String?  // fecha estimada de pago (YYYY-MM-DD)
  status            String   @default("pendiente") // pendiente | parcial | pagado
  note              String?  @db.Text
  refType           String?  // closing | manual ... (origen de la obligacion)
  refId             Int?     // id de referencia (p.ej. DailyClosing.id) para idempotencia
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([creditor])
  @@index([refType, refId])
  @@map("payables")
}

/// Abonos a una cuenta por pagar.
model PayablePayment {
  id          Int      @id @default(autoincrement())
  payableId   Int
  amount      Int
  paidDate    String // YYYY-MM-DD
  note        String?
  voucherPath String? // comprobante del pago subido (escaneo/foto firmado por Supergiros)
  paidBy      String? // quien hizo el pago (responsable del turno)
  createdAt   DateTime @default(now())

  @@index([payableId])
  @@map("payable_payments")
}

/// Anulacion de una venta (append-only: la venta no se borra, se reversa).
model Reversal {
  id           Int      @id @default(autoincrement())
  saleId       Int
  saleNumber   String
  reason       String?
  authorizedBy String?
  createdAt    DateTime @default(now())

  @@index([saleId])
  @@map("reversals")
}

/// Pagos hechos a los convenios/referidos (control de comisiones liquidadas).
model AllyPayment {
  id            Int      @id @default(autoincrement())
  allyId        Int?
  allyName      String
  amount        Int
  paidDate      String // YYYY-MM-DD
  note          String?
  voucherPath   String? // comprobante de pago subido (imagen/escaneo firmado)
  invoiceNumber String? // factura emitida a la cedula por el dinero de convenios
  plates        Json? // placas cubiertas por este pago
  convenioCount Int      @default(0) // cantidad de convenios/placas liquidados
  createdAt     DateTime @default(now())

  @@index([allyName])
  @@map("ally_payments")
}

/// Historial / log del cliente (append-only): como llego cada anio (directo|referido) y que hizo.
/// No es parte del perfil; se consulta como una bitacora. Sirve para detectar directo->referido.
model ClientHistory {
  id        Int      @id @default(autoincrement())
  clientDoc String
  saleId    Int?
  plate     String?
  year      Int
  eventType String // directo | referido | rtm | no_rtm
  allyId    Int?
  allyName  String?
  note      String?
  createdAt DateTime @default(now())

  @@index([clientDoc])
  @@index([year])
  @@map("client_history")
}

/// Cajas del negocio (caja menor, provisiones, IVA, etc.). Se pueden agregar mas.
/// kind: caja_menor | provision_rtm | provision_convenio | iva | otra
model CashBox {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  kind      String   @default("otra")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("cash_boxes")
}

/// Movimientos de caja (ingreso/egreso). Egreso+ingreso de provision al hacer RTM, dinero de convenios, etc.
model CashMovement {
  id        Int      @id @default(autoincrement())
  boxCode   String
  type      String // ingreso | egreso
  amount    Int
  refType   String? // sale | ally_payment | closing | manual ...
  refId     Int?
  date      String // YYYY-MM-DD
  note      String?
  createdAt DateTime @default(now())

  @@index([boxCode])
  @@index([date])
  @@map("cash_movements")
}

/// Control de FUPA/PIN (inventario de pines prepagados de Supergiros).
/// type: compra (+cantidad) | ajuste (delta +/- por conteo fisico).
/// El CONSUMO no se guarda aqui: se deriva de las RTM realizadas (sale.pinAdquirido>0),
/// asi se puede comparar stock teorico vs conteo real (detectar pines "quemados").
model FupaMovement {
  id        Int      @id @default(autoincrement())
  date      String   // YYYY-MM-DD
  type      String   // compra | ajuste
  quantity  Int      // compra: + ; ajuste: delta (+/-)
  unitCost  Int      @default(0)
  note      String?
  createdAt DateTime @default(now())

  @@index([date])
  @@map("fupa_movements")
}

/// Plantilla de ingresos (espejo de la hoja "Ingresos" del Excel gerencial).
/// Registro/clasificacion de ingresos por naturaleza y fuente (bancos | efectivo).
/// Opcionalmente acredita una caja (afectaCaja => CashMovement ingreso).
model Income {
  id          Int      @id @default(autoincrement())
  date        String   // YYYY-MM-DD
  value       Int
  observation String?
  natureCode  String?  // naturaleza (ingreso)
  source      String   @default("efectivo") // efectivo | bancos
  boxCode     String?  // caja acreditada (si afecta caja)
  note        String?
  createdBy   String?
  status      String   @default("activa") // activa | anulada
  createdAt   DateTime @default(now())

  @@index([date])
  @@index([natureCode])
  @@map("incomes")
}

/// Gastos del negocio. Cada gasto sale de una caja (genera CashMovement egreso).
/// Alimenta el "gastos" del cierre diario.
model Expense {
  id        Int      @id @default(autoincrement())
  date      String   // YYYY-MM-DD
  concept   String
  category  String?
  amount    Int
  boxCode   String   @default("CAJA_MENOR")
  note      String?
  createdBy String?
  status    String   @default("activa") // activa | anulada
  createdAt DateTime @default(now())

  @@index([date])
  @@index([category])
  @@index([boxCode])
  @@map("expenses")
}

/// Catalogo normalizado de naturalezas de ingreso/gasto para reportes gerenciales.
/// kind: ingreso | gasto | ambos
model ExpenseNature {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  kind        String   @default("gasto")
  taxRelevant Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([kind])
  @@map("expense_natures")
}

/// Proveedores (para ordenes de compra). Distintos de convenios/aliados.
model Supplier {
  id            Int      @id @default(autoincrement())
  docType       String   @default("NIT")
  docNumber     String   @unique
  name          String
  email         String?
  phone         String?
  address       String?
  paymentMethod String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([name])
  @@map("suppliers")
}

/// Facturas recibidas de proveedores. Base para cuentas por pagar e IVA descontable.
model SupplierInvoice {
  id            Int      @id @default(autoincrement())
  supplierId    Int?
  supplierDoc   String?
  supplierName  String
  number        String
  date          String   // YYYY-MM-DD
  dueDate       String?
  concept       String?
  natureCode    String?
  base          Int      @default(0)
  iva           Int      @default(0)
  total         Int      @default(0)
  deductible    Boolean  @default(true)
  source        String?  // manual | correo | dian | xml | pdf
  filePath      String?
  status        String   @default("pendiente") // pendiente | parcial | pagada | anulada
  paidAmount    Int      @default(0)
  paidDate      String?
  note          String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([supplierId])
  @@index([supplierDoc])
  @@index([date])
  @@index([status])
  @@index([natureCode])
  @@map("supplier_invoices")
}

/// Pagos/abonos hechos a facturas recibidas. Cada pago genera egreso de caja.
model SupplierInvoicePayment {
  id        Int      @id @default(autoincrement())
  invoiceId Int
  amount    Int
  paidDate  String   // YYYY-MM-DD
  boxCode   String   @default("CAJA_MENOR")
  note      String?
  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([boxCode])
  @@map("supplier_invoice_payments")
}

/// Orden de compra a un proveedor (cabecera). Lineas en PurchaseOrderLine.
model PurchaseOrder {
  id           Int      @id @default(autoincrement())
  number       String   @unique
  supplierId   Int?
  supplierName String
  date         String // YYYY-MM-DD
  concept      String?
  base         Int      @default(0)
  iva          Int      @default(0)
  total        Int      @default(0)
  status       String   @default("emitida") // emitida | anulada
  note         String?
  createdAt    DateTime @default(now())

  @@index([supplierId])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id          Int    @id @default(autoincrement())
  orderId     Int
  description String
  quantity    Int    @default(1)
  unitPrice   Int    @default(0)
  taxRate     Int    @default(0)
  base        Int    @default(0)
  tax         Int    @default(0)
  total       Int    @default(0)

  @@index([orderId])
  @@map("purchase_order_lines")
}

/// Factura electronica manual tipo POS (no la venta diaria de RTM): cualquier item.
model ManualInvoice {
  id         Int      @id @default(autoincrement())
  number     String   @unique
  clientDoc  String
  clientName String
  date       String // YYYY-MM-DD
  concept    String?
  base       Int      @default(0)
  iva        Int      @default(0)
  total      Int      @default(0)
  cufe       String?
  dianStatus String   @default("emitida_local") // emitida_local | aceptada | rechazada
  source     String? // origen: convenio | venta_equipo | otro
  status     String   @default("activa") // activa | anulada
  createdAt  DateTime @default(now())

  @@index([clientDoc])
  @@map("manual_invoices")
}

model ManualInvoiceLine {
  id          Int    @id @default(autoincrement())
  invoiceId   Int
  description String
  quantity    Int    @default(1)
  unitPrice   Int    @default(0)
  taxRate     Int    @default(0)
  base        Int    @default(0)
  tax         Int    @default(0)
  total       Int    @default(0)

  @@index([invoiceId])
  @@map("manual_invoice_lines")
}

/// Snapshot congelado del cierre diario (alimenta el consolidado).
model DailyClosing {
  id             Int      @id @default(autoincrement())
  closingDate    String   @unique
  salesTotal     Int      @default(0)
  byMethod       Json
  provision      Int      @default(0)
  receivableOpen Int      @default(0)
  jasperEstimado Int      @default(0)
  deducciones    Int      @default(0)
  cajaEfectivo   Int      @default(0)
  responsable    String?
  recibe         String?
  createdAt      DateTime @default(now())

  @@map("daily_closings")
}
